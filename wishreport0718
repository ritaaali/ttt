<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>心願進度報告 · 宜亭</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@300;400;500&family=Noto+Sans+TC:wght@300;400;500&display=swap');

  :root {
    --bg: #fdf8ee;
    --bg2: #f5edda;
    --paper: #fffdf5;
    --ink: #2a2018;
    --ink2: #5a4428;
    --ink3: #9a7a50;
    --gold: #c9a050;
    --accent: #8a6d3a;
    --rose: #b06060;
    --sage: #508050;
    --blue: #5068a0;
    --green: #4a8a4a;
    --yellow: #c9a050;
    --gray: #9a9a9a;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    font-family: 'Noto Sans TC', 'Hiragino Sans', sans-serif;
    color: var(--ink);
    min-height: 100vh;
    padding: 40px 24px 60px;
    max-width: 900px;
    margin: 0 auto;
  }

  /* HEADER */
  .header {
    text-align: center;
    margin-bottom: 40px;
    padding-bottom: 28px;
    border-bottom: 1px solid rgba(138,109,58,0.2);
  }

  .header-eyebrow {
    font-size: 11px;
    letter-spacing: 4px;
    color: var(--ink3);
    margin-bottom: 12px;
  }

  .header-wish {
    font-family: 'Noto Serif TC', serif;
    font-size: 32px;
    font-weight: 400;
    color: var(--ink);
    letter-spacing: 6px;
    margin-bottom: 8px;
  }

  .header-role {
    font-family: 'Noto Serif TC', serif;
    font-size: 18px;
    color: var(--accent);
    letter-spacing: 3px;
    margin-bottom: 16px;
  }

  .header-meta {
    display: flex;
    justify-content: center;
    gap: 20px;
    font-size: 12px;
    color: var(--ink3);
    letter-spacing: 1px;
  }

  .header-meta span {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .header-meta .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--gold);
  }

  /* LEGEND */
  .legend {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 28px;
    padding: 14px 18px;
    background: var(--paper);
    border-radius: 10px;
    border: 1px solid rgba(138,109,58,0.12);
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--ink2);
  }

  .status-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .s-active { background: #4a8a4a; }
  .s-slow { background: #c9a050; }
  .s-pause { background: #9a9a9a; }
  .s-done { background: #5068a0; }

  /* SECTION */
  .section {
    margin-bottom: 28px;
  }

  .section-title {
    font-size: 11px;
    letter-spacing: 4px;
    color: var(--accent);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(138,109,58,0.3), transparent);
  }

  /* TABLE */
  .table-wrap {
    background: var(--paper);
    border-radius: 12px;
    border: 1px solid rgba(138,109,58,0.12);
    overflow: hidden;
  }

  .table-head {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    background: var(--accent);
    padding: 12px 18px;
    gap: 12px;
  }

  .table-head span {
    font-size: 11px;
    letter-spacing: 2px;
    color: #fdf8ee;
    font-weight: 400;
  }

  .table-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    padding: 14px 18px;
    gap: 12px;
    border-bottom: 1px solid rgba(138,109,58,0.07);
    align-items: start;
    transition: background 0.15s;
  }

  .table-row:last-child {
    border-bottom: none;
  }

  .table-row:hover {
    background: rgba(138,109,58,0.03);
  }

  .row-label {
    font-size: 13px;
    color: var(--ink2);
    line-height: 1.6;
  }

  .row-label strong {
    display: block;
    font-size: 12px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 2px;
  }

  .row-cell {
    font-size: 12px;
    color: var(--ink2);
    line-height: 1.65;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    padding: 3px 9px;
    border-radius: 20px;
    margin-bottom: 4px;
  }

  .badge-active { background: rgba(74,138,74,0.12); color: #3a7a3a; }
  .badge-slow { background: rgba(201,160,80,0.15); color: #8a6020; }
  .badge-pause { background: rgba(154,154,154,0.12); color: #6a6a6a; }
  .badge-done { background: rgba(80,104,160,0.12); color: #3a5888; }
  .badge-new { background: rgba(176,96,96,0.12); color: #8a4848; }

  .change-arrow {
    display: inline-block;
    color: var(--green);
    font-size: 11px;
    margin-right: 3px;
  }

  .note {
    font-size: 11px;
    color: var(--ink3);
    margin-top: 3px;
    line-height: 1.5;
  }

  /* WISH CARD */
  .wish-card {
    background: linear-gradient(135deg, #7a5c2a 0%, #c9a050 100%);
    border-radius: 12px;
    padding: 20px 24px;
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  .wish-card-left .wish-label {
    font-size: 10px;
    letter-spacing: 3px;
    color: rgba(253,248,238,0.65);
    margin-bottom: 6px;
  }

  .wish-card-left .wish-main {
    font-family: 'Noto Serif TC', serif;
    font-size: 22px;
    color: #fdf8ee;
    letter-spacing: 4px;
  }

  .wish-card-left .wish-sub {
    font-size: 14px;
    color: rgba(253,248,238,0.8);
    letter-spacing: 2px;
    margin-top: 4px;
  }

  .wish-card-right {
    text-align: right;
  }

  .wish-card-right .change-label {
    font-size: 10px;
    letter-spacing: 2px;
    color: rgba(253,248,238,0.55);
    margin-bottom: 4px;
  }

  .wish-card-right .change-text {
    font-size: 12px;
    color: rgba(253,248,238,0.85);
    letter-spacing: 1px;
    line-height: 1.6;
  }

  /* SUB-SECTION */
  .sub-label {
    font-size: 11px;
    color: var(--ink3);
    letter-spacing: 2px;
    padding: 10px 18px;
    background: rgba(138,109,58,0.05);
    border-bottom: 1px solid rgba(138,109,58,0.07);
    font-weight: 500;
  }

  /* FOOTER */
  .footer {
    text-align: center;
    margin-top: 40px;
    font-size: 11px;
    color: var(--ink3);
    letter-spacing: 2px;
  }
</style>
</head>
